+
+#ifndef nsYardProtocolHandler_h__
+#define nsYardProtocolHandler_h__
+
+#include "nsIProtocolHandler.h"
+#include "nsIYardProtocolHandler.h"
+#include "nsString.h"
+
+#define NS_YARDPROTOCOLHANDLER_CONTRACTID "@mozilla.org/network/protocol;1?name=yard"
+#define NS_YARDPROTOCOLHANDLER_CID \
+  { 0xa1b2c3d4, 0xe5f6, 0x7890, \
+    { 0xab, 0xcd, 0xef, 0x12, 0x34, 0x56, 0x78, 0x90 } }
+
+class nsYardProtocolHandler : public nsIProtocolHandler,
+                               public nsIYardProtocolHandler {
+ public:
+  NS_DECL_ISUPPORTS
+  NS_DECL_NSIPROTOCOLHANDLER
+  NS_DECL_NSIYARDPROTOCOLHANDLER
+
+  nsYardProtocolHandler() = default;
+
+  static already_AddRefed<nsYardProtocolHandler> Create() {
+    RefPtr<nsYardProtocolHandler> handler = new nsYardProtocolHandler();
+    return handler.forget();
+  }
+
+ private:
+  virtual ~nsYardProtocolHandler() = default;
+};
+
+extern "C" already_AddRefed<nsYardProtocolHandler>
+NS_NewYardProtocolHandler();
+
+#endif  // nsYardProtocolHandler_h__
diff --git a/netwerk/protocol/yard/nsYardProtocolHandler.cpp b/netwerk/protocol/yard/nsYardProtocolHandler.cpp
